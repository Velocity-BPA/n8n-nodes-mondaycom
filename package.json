{
  "name": "n8n-nodes-mondaycom",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Monday.com providing 16 resource categories and 100+ operations for board, item, column, group, workspace, user, team, and document management. Includes webhook triggers and full GraphQL API support.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-mondaycom.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-mondaycom#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-mondaycom/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "monday",
    "monday.com",
    "project-management",
    "work-os",
    "graphql",
    "automation",
    "workflow",
    "boards",
    "items",
    "columns",
    "groups",
    "workspaces",
    "teams"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MondayComApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MondayCom/MondayCom.node.js",
      "dist/nodes/MondayCom/MondayComTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.2",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}